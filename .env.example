# SUPERIOR CRM — переменные окружения
# Скопируйте в .env и заполните свои значения

# ---- База данных (по умолчанию SQLite) ----
# DATABASE_URL=postgresql://user:pass@localhost:5432/superior_crm

# ---- Учётные записи по умолчанию (legacy, если нет Employee в БД) ----
# ADMIN_LOGIN=admin
# ADMIN_PASSWORD=admin
# TRAINER_LOGIN=trainer
# TRAINER_PASSWORD=trainer

# ---- Онлайн-эквайринг ----
# PAYMENT_PROVIDER=yookassa       # yookassa | tinkoff | mock
# YOOKASSA_SHOP_ID=...
# YOOKASSA_SECRET_KEY=...
# TINKOFF_TERMINAL_KEY=...
# TINKOFF_PASSWORD=...

# ---- Telegram ----
# BOT_TOKEN=...                     # токен бота от @BotFather
# BOT_CHANNEL_ID=@superior_gym      # @username канала
# BOT_WEBHOOK_URL=https://...       # публичный URL для webhook

# ---- Отладка ----
# TRACE=1                          # трассировка запросов (request/response body)
# CSRF_DISABLE=1                   # отключить CSRF (только для тестов/разработки)
